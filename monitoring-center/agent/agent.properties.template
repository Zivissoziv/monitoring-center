# Monitoring Agent Configuration File
# Copy this file to the same directory as monitoring-agent-1.0-SNAPSHOT.jar and modify as needed

# Agent Configuration
# Unique name for this agent (default: MonitoringAgent-<hostname>)
agent.name=Server1-Agent

# Port for agent HTTP server
agent.port=8081

# Metric Collection Configuration
# How often to collect and send metrics (in seconds)
metric.interval.seconds=10